<Window x:Class="InfinitariumManager.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Infinitarium Changelog Manager" Height="700" Width="1000"
        Background="#0b0b0f" Foreground="#f0f0f0" FontFamily="Consolas">

    <Window.Resources>
        <Style TargetType="TextBox">
            <Setter Property="Background" Value="#111111"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#333333"/>
            <Setter Property="Padding" Value="5"/>
            <Setter Property="CaretBrush" Value="White"/>
        </Style>

        <Style TargetType="ComboBox">
            <Setter Property="Background" Value="#111111"/>
            <Setter Property="Foreground" Value="#FFFFFF"/>
            <Setter Property="BorderBrush" Value="#333333"/>
        </Style>

        <Style TargetType="Button">
            <Setter Property="Cursor" Value="Hand"/>
        </Style>
    </Window.Resources>

    <Grid Margin="10">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
            <Button x:Name="BtnOpen" Content="Открыть HTML" Click="BtnOpen_Click" 
                    Background="#4d7cff" Foreground="White" Padding="10,5" Margin="0,0,10,0" FontWeight="Bold" BorderThickness="0"/>
            <Button x:Name="BtnSave" Content="Сохранить HTML" Click="BtnSave_Click" 
                    Background="#ff4d4d" Foreground="White" Padding="10,5" FontWeight="Bold" BorderThickness="0" IsEnabled="False"/>
            <TextBlock Text="Файл не выбран" x:Name="LblFilePath" VerticalAlignment="Center" Margin="10,0,0,0" Foreground="#aaa"/>
        </StackPanel>

        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="280"/>
                <ColumnDefinition Width="5"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <ListBox x:Name="LstVersions" Background="#1a1a20" BorderBrush="#333" Foreground="White"
                     SelectionChanged="LstVersions_SelectionChanged" BorderThickness="1">
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="FocusVisualStyle" Value="{x:Null}"/>
                        <Style.Triggers>
                            <Trigger Property="IsSelected" Value="True">
                                <Setter Property="Background" Value="#4d7cff"/>
                                <Setter Property="Foreground" Value="White"/>
                            </Trigger>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter Property="Background" Value="#2a2a35"/>
                            </Trigger>
                        </Style.Triggers>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel Margin="5">
                            <TextBlock Text="{Binding VersionTag}" FontWeight="Bold" FontSize="14" Foreground="#4d7cff"/>
                            <TextBlock Text="{Binding ButtonText}" FontSize="11" Foreground="#aaa" TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <GridSplitter Grid.Column="1" Width="5" HorizontalAlignment="Stretch" Background="Transparent"/>

            <ScrollViewer Grid.Column="2" VerticalScrollBarVisibility="Auto" Margin="10,0,0,0">
                <StackPanel>
                    <GroupBox Header="Информация о версии" BorderBrush="#333" Foreground="#ccc">
                        <GroupBox.HeaderTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" Foreground="#4d7cff" FontWeight="Bold"/>
                            </DataTemplate>
                        </GroupBox.HeaderTemplate>
                        <StackPanel Margin="5">
                            <TextBlock Text="ID (например: v2.6)" Foreground="#aaa" Margin="0,0,0,5"/>
                            <TextBox x:Name="TxtId" />

                            <TextBlock Text="Название кнопки" Foreground="#aaa" Margin="0,10,0,5"/>
                            <TextBox x:Name="TxtButtonLabel" />

                            <CheckBox x:Name="ChkUnreleased" Content="Unreleased (Красный стиль)" 
                                      Foreground="#ff9999" Margin="0,5,0,0"/>
                        </StackPanel>
                    </GroupBox>

                    <GroupBox Header="Список изменений" BorderBrush="#333" Foreground="#ccc" Margin="0,10,0,0">
                        <GroupBox.HeaderTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}" Foreground="#4d7cff" FontWeight="Bold"/>
                            </DataTemplate>
                        </GroupBox.HeaderTemplate>
                        <StackPanel>
                            <TextBlock Text="Добавьте секции (Additions, Improvements...)" Foreground="#666" FontSize="12" Margin="0,0,0,10"/>

                            <ItemsControl x:Name="ListSections">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <Border Background="#15151a" BorderBrush="#444" BorderThickness="1" Margin="0,0,0,15" Padding="15" CornerRadius="5">
                                            <StackPanel>
                                                <Grid>
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>

                                                    <ComboBox x:Name="CmbType" 
                                                              SelectedItem="{Binding Type, Mode=TwoWay}"
                                                              ItemsSource="{Binding DataContext.SectionTypes, RelativeSource={RelativeSource AncestorType=Window}}"
                                                              Margin="0,0,10,0"/>

                                                    <TextBox x:Name="TxtCustomTitle" Grid.Column="0" 
                                                             Text="{Binding CustomTitle, UpdateSourceTrigger=PropertyChanged}"
                                                             Visibility="{Binding IsCustomVisible}"
                                                             Foreground="#ff994d" 
                                                             Margin="0,0,10,5" />

                                                    <Button Grid.Column="1" Content="✕" Click="BtnRemoveSection_Click" 
                                                            Tag="{Binding}" Background="#331111" Foreground="#ff4d4d" 
                                                            BorderBrush="#ff4d4d" BorderThickness="1"
                                                            Width="30" Height="30" FontWeight="Bold"/>
                                                </Grid>

                                                <TextBlock Text="Пункты списка (каждый с новой строки):" Foreground="#888" FontSize="11" Margin="0,10,0,5"/>

                                                <TextBox x:Name="TxtItems" Text="{Binding ItemsText, UpdateSourceTrigger=PropertyChanged}"
                                                         AcceptsReturn="True" TextWrapping="Wrap"
                                                         Height="120" VerticalScrollBarVisibility="Auto"
                                                         FontFamily="Consolas" FontSize="13"/>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <Button Content="+ Добавить секцию" Click="BtnAddSection_Click" 
                                    Background="#1a1a20" Foreground="#4d7cff" BorderBrush="#4d7cff" BorderThickness="1"
                                    Margin="0,5,0,20" Padding="8"/>
                        </StackPanel>
                    </GroupBox>

                    <StackPanel Orientation="Horizontal" Margin="0,10,0,0">
                        <Button Content="Сохранить версию" Click="BtnUpdateVersion_Click" 
                                Background="#4d7cff" Foreground="White" Padding="15,8" Margin="0,0,10,0" FontWeight="Bold" BorderThickness="0"/>
                        <Button Content="Новая версия" Click="BtnNewVersion_Click" 
                                Background="#222" Foreground="#4d7cff" Padding="15,8" Margin="0,0,10,0" BorderBrush="#4d7cff" BorderThickness="1"/>
                        <Button Content="Удалить" Click="BtnDeleteVersion_Click" 
                                Background="#333" Foreground="#ff4d4d" Padding="15,8" BorderThickness="0"/>

                        <Separator Width="1" Background="#333" Margin="10,0"/>

                        <Button Content="Экспорт версии (.txt)" Click="BtnExportSingleTxt_Click" 
                            Background="#1a1a20" Foreground="#aaa" Padding="10,8" Margin="0,0,5,0" BorderBrush="#444" BorderThickness="1" ToolTip="Сохранить changelog текущей выбранной версии в TXT"/>

                        <Button Content="Экспорт всего (.txt)" Click="BtnExportAllTxt_Click" 
                            Background="#1a1a20" Foreground="#aaa" Padding="10,8" BorderBrush="#444" BorderThickness="1" ToolTip="Сохранить полный список изменений всех версий в один TXT файл"/>
                    </StackPanel>
                </StackPanel>
            </ScrollViewer>
        </Grid>

        <StatusBar Grid.Row="2" Background="#050508" Foreground="#aaa" BorderBrush="#333">
            <StatusBarItem>
                <TextBlock x:Name="LblStatus">Готов к работе</TextBlock>
            </StatusBarItem>
        </StatusBar>
    </Grid>
</Window>